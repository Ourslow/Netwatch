{
  "uid": "netwatch-snmp-ifaces",
  "title": "NetWatch — SNMP Interfaces",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["netwatch", "snmp", "interfaces"],
  "templating": {
    "list": [
      {
        "name": "device",
        "label": "Équipement",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": {
          "query": "label_values(netwatch:iface_bytes_rate, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Interfaces SNMP",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Débit In/Out — Top 10 interfaces (bytes/s)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, netwatch:iface_bytes_rate{instance=~\"$device\"})",
          "legendFormat": "In — {{instance}} {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, rate(ifHCOutOctets{job=\"snmp\",instance=~\"$device\"}[5m]))",
          "legendFormat": "Out — {{instance}} {{ifDescr}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "table",
      "title": "Résumé interfaces — Utilisation %",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Utilisation %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 70 },
                  { "color": "red", "value": 90 }
                ]
              }},
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Utilisation %", "desc": true }],
        "footer": { "show": false }
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "Débit In (bytes/s)",
              "Value #B": "Utilisation %",
              "ifDescr": "Interface",
              "instance": "Équipement"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "netwatch:iface_bytes_rate{instance=~\"$device\"}",
          "instant": true,
          "legendFormat": "{{instance}} — {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "netwatch:iface_bytes_rate{instance=~\"$device\"} / (ifHighSpeed{job=\"snmp\",instance=~\"$device\"} * 125000) * 100",
          "instant": true,
          "legendFormat": "{{instance}} — {{ifDescr}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 100,
      "type": "row",
      "title": "Capacity Planning",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "panels": []
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Interfaces critiques (<7j)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(netwatch:iface_days_to_saturation{instance=~\"$device\"} < 7) or vector(0)",
          "instant": true,
          "legendFormat": "Critiques",
          "refId": "A"
        }
      ]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Interfaces sous tension (7-30j)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(netwatch:iface_days_to_saturation{instance=~\"$device\"} >= 7 and netwatch:iface_days_to_saturation{instance=~\"$device\"} <= 30) or vector(0)",
          "instant": true,
          "legendFormat": "Sous tension",
          "refId": "A"
        }
      ]
    }
  ]
}
