{
  "uid": "netwatch-beacons",
  "title": "NetWatch — Beacon Detector (RITA-lite)",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["netwatch", "ml", "behavioral", "rita", "c2"],
  "description": "Détection comportementale : beaconing C2, longues connexions, DNS tunneling",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Beacons C2 détectés",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
        "query": "detection_type: beaconing",
        "metrics": [{ "id": "1", "type": "count" }],
        "bucketAggs": []
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Longues connexions",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 3 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
        "query": "detection_type: long_connection",
        "metrics": [{ "id": "1", "type": "count" }],
        "bucketAggs": []
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DNS Tunneling indicators",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 3 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
        "query": "detection_type: dns_tunneling",
        "metrics": [{ "id": "1", "type": "count" }],
        "bucketAggs": []
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Score max (beacon score)",
      "description": "1.0 = connexions parfaitement régulières = fort indicateur C2",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.7 },
            { "color": "red", "value": 0.85 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
        "query": "*",
        "metrics": [{ "id": "1", "type": "max", "field": "beacon_score" }],
        "bucketAggs": []
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Détections dans le temps",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "drawStyle": "bars" }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
          "query": "detection_type: beaconing",
          "alias": "Beaconing C2",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "30m", "min_doc_count": "0" } }]
        },
        {
          "refId": "B",
          "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
          "query": "detection_type: long_connection",
          "alias": "Longue connexion",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "30m", "min_doc_count": "0" } }]
        },
        {
          "refId": "C",
          "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
          "query": "detection_type: dns_tunneling",
          "alias": "DNS Tunneling",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "30m", "min_doc_count": "0" } }]
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Beacons C2 — Top suspects (score > 0.7)",
      "description": "CV = coefficient de variation des intervalles. Plus il est bas, plus les connexions sont régulières → fort indicateur de beacon C2.",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 12 },
      "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "beacon_score" }, "properties": [
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "yellow", "value": null },
              { "color": "orange", "value": 0.75 },
              { "color": "red", "value": 0.9 }
            ]}}
          ]}
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "beacon_score", "desc": true }] },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
        "query": "detection_type: beaconing AND beacon_score: [0.7 TO *]",
        "metrics": [
          { "id": "1", "type": "max", "field": "beacon_score" },
          { "id": "2", "type": "max", "field": "mean_interval_s" },
          { "id": "3", "type": "max", "field": "connection_count" },
          { "id": "4", "type": "max", "field": "cv" }
        ],
        "bucketAggs": [
          { "id": "5", "type": "terms", "field": "src_ip.keyword", "settings": { "size": "20", "order": "desc", "orderBy": "1" } },
          { "id": "6", "type": "terms", "field": "dst_ip.keyword", "settings": { "size": "3", "order": "desc", "orderBy": "1" } },
          { "id": "7", "type": "terms", "field": "dst_port", "settings": { "size": "1", "order": "desc", "orderBy": "1" } }
        ]
      }]
    },
    {
      "id": 7,
      "type": "table",
      "title": "DNS Tunneling — Requêtes suspectes",
      "description": "Sous-domaines très longs (> 40 chars) ou haute fréquence = exfiltration via DNS possible.",
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 12 },
      "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "beacon_score", "desc": true }] },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
        "query": "detection_type: dns_tunneling",
        "metrics": [
          { "id": "1", "type": "max", "field": "beacon_score" },
          { "id": "2", "type": "max", "field": "subdomain_length" },
          { "id": "3", "type": "max", "field": "query_count" }
        ],
        "bucketAggs": [
          { "id": "4", "type": "terms", "field": "src_ip.keyword", "settings": { "size": "10", "order": "desc", "orderBy": "1" } },
          { "id": "5", "type": "terms", "field": "query.keyword", "settings": { "size": "3", "order": "desc", "orderBy": "1" } }
        ]
      }]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Longues connexions — Tunnels potentiels",
      "description": "Connexions ouvertes > 1h. Peut indiquer un reverse shell, tunnel SSH, exfiltration lente.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "duration_h" }, "properties": [
            { "id": "unit", "value": "h" },
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "yellow", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 6 }
            ]}}
          ]},
          { "matcher": { "id": "byName", "options": "orig_bytes" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "resp_bytes" }, "properties": [{ "id": "unit", "value": "bytes" }] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "duration_h", "desc": true }] },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "elasticsearch", "uid": "beacons-es" },
        "query": "detection_type: long_connection",
        "metrics": [
          { "id": "1", "type": "max", "field": "duration_h" },
          { "id": "2", "type": "max", "field": "orig_bytes" },
          { "id": "3", "type": "max", "field": "resp_bytes" }
        ],
        "bucketAggs": [
          { "id": "4", "type": "terms", "field": "src_ip.keyword", "settings": { "size": "20", "order": "desc", "orderBy": "1" } },
          { "id": "5", "type": "terms", "field": "dst_ip.keyword", "settings": { "size": "3", "order": "desc", "orderBy": "1" } },
          { "id": "6", "type": "terms", "field": "proto.keyword", "settings": { "size": "1", "order": "desc", "orderBy": "1" } }
        ]
      }]
    }
  ]
}
