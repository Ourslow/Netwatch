{
  "uid": "netwatch-ja3hassh",
  "title": "NetWatch — JA3/HASSH Fingerprinting",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["netwatch", "zeek", "tls", "ssh", "fingerprinting"],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Connexions TLS",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "ja3:*",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": []
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "JA3 Hashes Uniques",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 20 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "ja3:*",
          "metrics": [{ "id": "1", "type": "cardinality", "field": "ja3.keyword" }],
          "bucketAggs": []
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Connexions SSH",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "hassh:*",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": []
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "HASSH Hashes Uniques",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "hassh:*",
          "metrics": [{ "id": "1", "type": "cardinality", "field": "hassh.keyword" }],
          "bucketAggs": []
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Connexions TLS et SSH dans le temps",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "datasource", "uid": "-- Mixed --" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "ja3:*",
          "alias": "TLS (JA3)",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } }]
        },
        {
          "refId": "B",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "hassh:*",
          "alias": "SSH (HASSH)",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [{ "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } }]
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top JA3 — Clients TLS (fingerprint navigateur/outil)",
      "description": "Un JA3 hash identifie un client TLS. Des outils comme curl, Metasploit, Cobalt Strike ont des JA3 connus.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "ja3:*",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [{ "id": "2", "type": "terms", "field": "ja3.keyword", "settings": { "size": "15", "order": "desc", "orderBy": "1" } }]
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top JA3S — Serveurs TLS (fingerprint serveur)",
      "description": "JA3S identifie la réponse du serveur TLS — utile pour détecter des C2 avec TLS custom.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "ja3s:*",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [{ "id": "2", "type": "terms", "field": "ja3s.keyword", "settings": { "size": "15", "order": "desc", "orderBy": "1" } }]
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top HASSH — Clients SSH (fingerprint implémentation)",
      "description": "HASSH identifie l'implémentation SSH cliente — OpenSSH vs Paramiko vs PuTTY vs Metasploit.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "hassh:*",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [{ "id": "2", "type": "terms", "field": "hassh.keyword", "settings": { "size": "15", "order": "desc", "orderBy": "1" } }]
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "JA3 par SNI (Server Name Indication)",
      "description": "Corrèle chaque JA3 client avec le domaine contacté — détecte les outils qui se font passer pour des navigateurs.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "zeek-es" },
          "query": "ja3:* AND server_name:*",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "terms", "field": "server_name.keyword", "settings": { "size": "10", "order": "desc", "orderBy": "1" } },
            { "id": "3", "type": "terms", "field": "ja3.keyword", "settings": { "size": "3", "order": "desc", "orderBy": "1" } }
          ]
        }
      ]
    }
  ]
}
