# Copier en .env et remplir avant de lancer
# Le fichier .env n'est jamais commité

# Proxmox
PROXMOX_HOST=
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=votre_mot_de_passe
PROXMOX_NODE=pve
PROXMOX_VERIFY_SSL=false

# Flask
FLASK_SECRET_KEY=changeme-secret-key-random
FLASK_DEBUG=false
PORT=5050

# Services NetWatch (laisser vides si non déployés)
NETWATCH_ES_URL=http://localhost:9200
NETWATCH_GRAFANA_URL=http://localhost:3000
NETWATCH_PROMETHEUS_URL=http://localhost:9090
NETWATCH_AUTOBLOCK_URL=http://localhost:5001
