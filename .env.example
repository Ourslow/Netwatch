# Copier ce fichier en .env et remplir les valeurs
# Le fichier .env n'est pas commité (voir .gitignore)

# Interface réseau de capture (vérifier avec: ip a)
# Exemples : eth0, ens18, enp6s18
IFACE=ens18

# IP du serveur à surveiller spécifiquement (règles Snort 1000013-1000016)
SNORT_MONITORED_SERVER=x.x.x.x

# Webhook Slack pour les alertes Grafana (optionnel)
# Obtenir sur : https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
