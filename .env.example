# Copier ce fichier en .env et remplir les valeurs AVANT de lancer docker compose
# Le fichier .env n'est jamais commité (voir .gitignore)
# ATTENTION : ne jamais commiter .env sur GitHub

# Interface réseau de capture (vérifier avec: ip a)
# Exemples : eth0, ens18, enp6s18
IFACE=ens18

# IP du serveur à surveiller spécifiquement (règles Snort 1000013-1000016)
SNORT_MONITORED_SERVER=x.x.x.x

# Mot de passe admin Grafana (défaut: changeme — à changer impérativement)
GRAFANA_ADMIN_PASSWORD=changeme

# Webhook Slack pour les alertes Grafana (optionnel)
# Obtenir sur : https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
