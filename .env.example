# Copier ce fichier en .env et remplir les valeurs AVANT de lancer docker compose
# Le fichier .env n'est jamais commité (voir .gitignore)
# ATTENTION : ne jamais commiter .env sur GitHub

# Interface réseau de capture (vérifier avec: ip a)
# Exemples : eth0, ens18, enp6s18
IFACE=ens18

# IP du serveur à surveiller spécifiquement (règles Snort 1000013-1000016)
SNORT_MONITORED_SERVER=x.x.x.x

# Mot de passe admin Grafana (défaut: changeme — à changer impérativement)
GRAFANA_ADMIN_PASSWORD=changeme

# Webhook Slack pour les alertes Grafana (optionnel)
# Obtenir sur : https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# AutoBlock — réponse automatique iptables
# DRY_RUN=true = simule les blocs sans appliquer iptables (recommande pour commencer)
# DRY_RUN=false = blocs reels via iptables (necessite de tester d'abord en dry-run)
AUTOBLOCK_DRY_RUN=true
BLOCK_DURATION_MIN=60
# IPs a ne JAMAIS bloquer (gateway, DNS internes, serveurs critiques) — separees par virgule
AUTOBLOCK_ALLOWLIST=192.168.1.1,192.168.1.254
# Secret partagé pour authentifier les appels au webhook AutoBlock (block/unblock/alert).
# OBLIGATOIRE en mode LIVE (DRY_RUN=false) — sinon les blocages sont refusés (fail-safe).
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
# Côté Grafana, ajouter le token dans l'URL du contact point : .../webhook/alert?token=VOTRE_SECRET
AUTOBLOCK_WEBHOOK_SECRET=

# Assistant IA local (Ollama) — explication des alertes IDS dans le portail web
# Premier lancement après "docker compose up -d" :
#   docker exec netwatch-ollama ollama pull mistral
OLLAMA_MODEL=mistral
